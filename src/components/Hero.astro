---
import { clsx } from 'clsx';
---

<div class="hero-bg">
  <div class="hero-container index-gradient xl:py-20">
    <div class="container mx-auto text-white conf-block px-4">
      <section
        class={clsx(
          'flex-wrap gap-14 justify-center items-center flex max-sm:flex-col',
          '[&_h3]:text-white [&_h3]:text-2xl max-lg:[&_h3]:text-center [&_p]:text-white/80 [&_p]:text-center',
          '[&_pre]:!bg-transparent [&_pre]:ring-0 [&_pre_span]:text-[--shiki-dark]',
          '[&_h3]:font-extralight',
          '[&_code]:whitespace-pre-wrap'
        )}
      >
        <div class="max-md:grow max-xl:w-full flex flex-col items-center gap-8 py-8">
          <img src="/icons/lgd-hero.svg" alt="Local Guides Directory" class="w-52" />
        </div>

        <div>
          <h3>Calling all Local Guides!</h3>
          <p>
            Want to connect with fellow Local Guides in your city or worldwide?
            Local Guides Directory (LGD) makes it easy!
          </p>
        </div>
      </section>

      <a class="block w-fit mx-auto mt-10" href="https://play.google.com/" target="_blank" rel="noreferrer">
        <span class="gap-4 bg-orange-800 hover:bg-orange-600 text-white font-bold p-4 px-4 rounded inline-flex items-center">
          <img src="/icons/google-play-store.svg" alt="Google Play" class="w-6 h-6 invert" />
          <span>Google Play Store</span>
        </span>
      </a>
    </div>
  </div>
</div>
