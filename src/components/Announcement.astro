---
import { announcement } from '../config/announcement';
---

{announcement.enabled && (
  <div
    id="announcement"
    data-announcement-id={announcement.id}
    class="fixed inset-x-0 top-0 z-50 h-10 flex items-center justify-center bg-primary text-white px-4 text-sm font-medium"
  >
    <span set:html={announcement.message} />
    <button
      id="close-announcement"
      class="absolute right-4 top-1/2 -translate-y-1/2 hover:opacity-75 transition-opacity"
      aria-label="Dismiss"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>
)}
